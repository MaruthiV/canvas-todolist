# Copy this file to ".env" and fill in your Supabase project values.
# URL: the Connect button (top) or Settings → Data API.
# Key: Settings → API Keys → the "Publishable key" (sb_publishable_...).
#   It's safe in a browser (access is guarded by RLS). Do NOT use the secret key.
VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
